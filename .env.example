# Salin file ini menjadi .env.local, lalu isi dari Supabase Dashboard > Connect.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Credential Google Calendar TIDAK diletakkan di file frontend ini.
# Simpan GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, dan encryption key sebagai Supabase Edge Function Secrets.
